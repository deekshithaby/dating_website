# Copy to `.env.local` and fill in. Do not commit `.env.local`.

# Supabase (Dashboard → Project Settings → API)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Server-only — never use NEXT_PUBLIC_ for this key; do not import in client code.
SUPABASE_SERVICE_ROLE_KEY=

# Cloudflare R2 (S3-compatible uploads; optional until photo upload is wired)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET_NAME=
R2_PUBLIC_URL=

# SMS (e.g. Fast2SMS for Supabase Auth Send SMS hook)
FAST2SMS_API_KEY=
